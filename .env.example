# Copy this to .env.local (gitignored) and fill in real values from your
# Supabase project settings (Project Settings -> API). Never commit .env.local.

# Public by design — RLS in supabase/schema.sql is what actually protects
# data, not secrecy of these two values.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SERVER-ONLY. Never prefix with NEXT_PUBLIC_, never import from anything
# under components/ — it bypasses Row Level Security entirely. Used by
# scripts/seed.mjs (local, one-off) and by lib/supabase/admin.js, which
# gates every use behind an admin-only API route or the cron secret below.
SUPABASE_SERVICE_ROLE_KEY=

# Optional. Secures /api/cron/ojt-reminders — Vercel sends this as
# `Authorization: Bearer $CRON_SECRET` automatically once both this env var
# and vercel.json's cron entry exist. Any random long string works.
CRON_SECRET=

# Comma-separated. Only these addresses may request a magic-link sign-in —
# checked server-side in app/api/auth/request-link before Supabase ever
# sends an email.
ALLOWED_EMAILS=you@example.com,apprentice@example.com

# Optional. Sends a "your password changed" notification email. Silently
# no-ops if unset — see lib/email.js.
RESEND_API_KEY=

# Apprentice self-signup (app/signup, app/api/auth/sign-up) is now a live
# admin toggle — Settings → Apprentice Sign-Up in the admin panel — backed
# by app_settings.self_signup_enabled in Supabase, not an env var. No env
# var needed here; the toggle takes effect immediately, no redeploy. A
# self-signed-up account still can't do anything until an admin approves it
# (profiles.approved_at) regardless of this setting.

# Optional, both together. Turns on "Upload OJT slips" (bulk PDF/photo import
# with AI extraction of past OJT months) on /pending and the in-app OJT tab.
# ANTHROPIC_API_KEY is a server-only secret (get one at console.anthropic.com)
# used only by app/api/ojt-months/extract — never exposed to the client.
# Uploaded files are never stored; they're read once for extraction and
# discarded. Off by default: manual month entry (already shipped) keeps
# working exactly as-is either way. Set both to "true"/a real key together.
ANTHROPIC_API_KEY=
NEXT_PUBLIC_OJT_IMPORT_ENABLED=
